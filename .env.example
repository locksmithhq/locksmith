# Database
POSTGRES_HOST=database
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=locksmith
POSTGRES_PORT=5432
SCHEMA=locksmith
SSL_MODE=disable

LOCKSMITH_APP_PORT=4000
LOCKSMITH_BASE_URL=http://localhost:4000
LOCKSMITH_APP_CLIENT_SECRET=your_client_secret
LOCKSMITH_APP_CLIENT_ID=your_client_id

# AES-256-GCM key for encrypting oauth_clients.client_secret and social provider credentials at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_base64_32byte_key

# Set to "production" to hide internal stack traces from API error responses.
# In production, errors return only "message" and "error_id" for log correlation.
APP_ENV=development

# Seeder credentials — required on first boot. Change before any production deploy.
SEED_ADMIN_EMAIL=admin@locksmith.rs
SEED_ADMIN_PASSWORD=your_admin_password
SEED_APP_CLIENT_ID=your_app_client_id
SEED_APP_CLIENT_SECRET=your_app_client_secret
SEED_APP_USER_PASSWORD=your_app_user_password
